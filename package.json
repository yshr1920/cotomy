{
  "name": "cotomy",
  "version": "2.0.2",
  "main": "dist/cjs/index.cjs",
  "module": "dist/esm/index.js",
  "types": "dist/types/index.d.ts",
  "browser": "dist/esm/index.js",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.cjs",
      "default": "./dist/esm/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "unpkg": "dist/browser/cotomy.min.js",
  "scripts": {
    "build": "npm run clean && npm run build:esm && npm run build:cjs && npm run build:browser",
    "build:esm": "tsc --project tsconfig.esm.json",
    "build:cjs": "webpack --config webpack.config.cjs --mode=production",
    "build:browser": "webpack --config webpack.config.browser.cjs",
    "dev": "webpack --config webpack.config.cjs --mode=development",
    "clean": "rimraf dist",
    "test": "vitest run",
    "prepare": "npm run build",
    "release": "npm run clean && npm run build && npm version patch && npm publish",
    "check": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write src"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "description": "",
  "type": "module",
  "devDependencies": {
    "@types/jsdom": "^28.0.1",
    "jsdom": "^29.0.1",
    "rimraf": "^6.1.3",
    "ts-loader": "^9.5.7",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2",
    "webpack": "^5.105.4",
    "webpack-cli": "^7.0.2"
  },
  "dependencies": {
    "@paralleldrive/cuid2": "^2.2.2",
    "dayjs": "^1.11.20",
    "http-status-codes": "^2.3.0",
    "locale-currency": "^1.0.0"
  }
}
